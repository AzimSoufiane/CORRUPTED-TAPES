    <script>
        // Set Year
        document.getElementById('year').innerText = new Date().getFullYear();

        // Create Background Texture
        const texture = document.getElementById('texture-overlay');
        const phrase = "MY AFFECTION NEVER ACTUALLY LEAVES ";
        const count = 500; // Adjust based on page length
        
        let content = "";
        for(let i = 0; i < count; i++) {
            content += phrase;
        }
        texture.innerText = content;

        // Subtle Parallax effect on scroll for texture
        window.addEventListener('scroll', () => {
            const scrolled = window.pageYOffset;
            texture.style.transform = `translateY(${scrolled * 0.1}px)`;
        });
    </script>
